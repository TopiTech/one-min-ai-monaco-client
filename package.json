{
  "name": "one-min-ai-monaco-client",
  "version": "1.0.0",
  "description": "Browser AI client using Monaco Editor + custom UI + 1min.ai API proxy",
  "type": "module",
  "scripts": {
    "copy-monaco": "node scripts/copy-monaco.js",
    "copy-vendor": "node scripts/copy-vendor.js",
    "start": "node scripts/copy-vendor.js && node scripts/copy-monaco.js && node server.js",
    "dev": "node scripts/copy-vendor.js && node scripts/copy-monaco.js && node --watch server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"server.js\" \"{public,routes,utils,config,services,tests}/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"server.js\" \"{public,routes,utils,config,services,tests}/**/*.{js,css,html}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "cookie": "^2.0.1",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "js-tiktoken": "^1.0.21",
    "marked": "^18.0.5",
    "monaco-editor": "^0.55.1",
    "multer": "^2.1.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "dompurify": "^3.4.11"
  },
  "devDependencies": {
    "@eslint/css": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.3",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "supertest": "^7.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "maxWorkers": 2,
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
