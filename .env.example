# 1min.ai API key. Never put this in public frontend code.
ONE_MIN_AI_API_KEY=your_1min_ai_api_key_here

# Server configuration
PORT=3000
# NODE_ENV: "development" (default) enables stack traces in error responses.
# Set to "production" for public-facing deployments.
NODE_ENV=development

# File upload limits (in bytes, default: 25MB)
MAX_FILE_SIZE=26214400

# JSON body size limit
MAX_JSON_BODY_SIZE=2mb

# API settings
API_TIMEOUT=60000
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY=2000

# Override 1min.ai API base URL (for mock servers or staging)
# ONE_MIN_AI_API_BASE_URL=https://api.1min.ai

# Default models
DEFAULT_CHAT_MODEL=gpt-4o-mini
DEFAULT_CODE_MODEL=qwen3-coder-plus
DEFAULT_IMAGE_MODEL=gpt-image-2
DEFAULT_IMAGE_EDITOR_MODEL=gpt-image-2

# Rate limiting (per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=180
RATE_LIMIT_AUTOCOMPLETE_MAX=600
RATE_LIMIT_CHAT_MAX=300

# Session TTL for agent sessions (ms)
SESSION_TTL_MS=1800000

# Workspace and agent settings
# ALLOWED_ROOTS: Comma-separated absolute paths for additional allowed directories.
# Example: ALLOWED_ROOTS=C:\Users\Documents\projects,D:\work
# If empty, only PROJECT_ROOT (this project directory) is allowed.
ALLOWED_ROOTS=
ENABLE_COMMAND_EXECUTION=false
COMMAND_TIMEOUT_MS=30000
AGENT_AUTO_APPROVE=false
# AGENT_MAX_LOOPS: Maximum number of agent loop iterations (1-100, default: 20).
AGENT_MAX_LOOPS=20
# ENABLE_DRIVES_SHELL_LOOKUP: Use PowerShell/wmic to enumerate drives (default: true).
# ENABLE_DRIVES_SHELL_LOOKUP=true

# Local BFF authentication
# LOCAL_BFF_AUTH_TOKEN: Fixed token for local BFF auth (otherwise auto-generated per start).
# LOCAL_BFF_AUTH_TOKEN=your-secret-token

# Logging
LOG_LEVEL=info
# Set to "true" to also write logs to logs/app-YYYY-MM-DD.log (auto-created).
LOG_TO_FILE=false
# LOG_FILE: Custom log file path (default: logs/app.log).
# LOG_FILE=logs/app.log
