{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": [
    "server.js",
    "config/**/*.js",
    "routes/**/*.js",
    "utils/**/*.js",
    "services/**/*.js",
    "middlewares/**/*.js"
  ],
  "exclude": ["node_modules", "tests"]
}
